{
  "name": "mojix-picker",
  "version": "0.5.5",
  "description": "Universal React emoji picker with spritesheet support, CDN/local sources, headless primitives, and a minimal modern UI.",
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./locales/de": {
      "types": "./dist/lib/entries/locales/de.d.ts",
      "import": "./dist/lib/locales/de.js",
      "require": "./dist/lib/locales/de.cjs"
    },
    "./locales/en": {
      "types": "./dist/lib/entries/locales/en.d.ts",
      "import": "./dist/lib/locales/en.js",
      "require": "./dist/lib/locales/en.cjs"
    },
    "./locales/es": {
      "types": "./dist/lib/entries/locales/es.d.ts",
      "import": "./dist/lib/locales/es.js",
      "require": "./dist/lib/locales/es.cjs"
    },
    "./locales/fr": {
      "types": "./dist/lib/entries/locales/fr.d.ts",
      "import": "./dist/lib/locales/fr.js",
      "require": "./dist/lib/locales/fr.cjs"
    },
    "./locales/ja": {
      "types": "./dist/lib/entries/locales/ja.d.ts",
      "import": "./dist/lib/locales/ja.js",
      "require": "./dist/lib/locales/ja.cjs"
    },
    "./locales/pt": {
      "types": "./dist/lib/entries/locales/pt.d.ts",
      "import": "./dist/lib/locales/pt.js",
      "require": "./dist/lib/locales/pt.cjs"
    },
    "./locales/ru": {
      "types": "./dist/lib/entries/locales/ru.d.ts",
      "import": "./dist/lib/locales/ru.js",
      "require": "./dist/lib/locales/ru.cjs"
    },
    "./locales/uk": {
      "types": "./dist/lib/entries/locales/uk.d.ts",
      "import": "./dist/lib/locales/uk.js",
      "require": "./dist/lib/locales/uk.cjs"
    },
    "./presets": {
      "types": "./dist/lib/entries/presets/index.d.ts",
      "import": "./dist/lib/presets/index.js",
      "require": "./dist/lib/presets/index.cjs"
    },
    "./style.css": "./dist/lib/style.css"
  },
  "files": [
    "dist/lib"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/lib/locales/*.js",
    "./dist/lib/locales/*.cjs"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "vite",
    "prepare": "node ./scripts/build-emoji-data.mjs",
    "emoji:data": "node ./scripts/build-emoji-data.mjs",
    "build:demo": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:package": "npm run emoji:data && npm run build:lib",
    "build": "npm run emoji:data && npm run build:demo && npm run build:lib",
    "prepack": "npm run build:package",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build:package",
    "pack:check": "node ./scripts/check-package.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.lib.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "keywords": [
    "emoji",
    "emoji-picker",
    "picker",
    "react",
    "react-component",
    "spritesheet",
    "twemoji",
    "unicode",
    "cldr",
    "headless",
    "i18n",
    "tsx"
  ],
  "author": "Xentaii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xentaii/MojiX.git"
  },
  "bugs": {
    "url": "https://github.com/Xentaii/MojiX/issues"
  },
  "homepage": "https://github.com/Xentaii/MojiX#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cldr-annotations-full": "^48.2.0",
    "emoji-datasource": "^16.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  }
}
